{
  "name": "ea-builder-pro",
  "private": true,
  "version": "1.1.5",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "YourName",
  "description": "Professional EA Builder Application",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/ea-builder-pro"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "node -e \"const fs=require('fs'); fs.rmSync('release', {recursive:true, force:true})\" && vite build && dotenv -- electron-builder --publish always",
    "release": "npm version patch && git push --follow-tags && npm run dist",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.eabuilder.pro",
    "productName": "EA Builder Pro",
    "asar": true,
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Michaelstwn",
        "repo": "ea-builder-pro"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EA Builder Pro"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.24.0",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
